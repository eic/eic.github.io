---
layout: null
search_exclude: true
---
[
{%- assign emitted = false -%}
{%- for doc in site.pages -%}
  {%- if doc.title and doc.search_exclude != true and doc.url != '/404.html' and doc.url != '/assets/js/search-data.json' -%}
    {%- if emitted -%},{%- endif -%}
    {%- include layouts/search_doc.json doc=doc collection='page' -%}
    {%- assign emitted = true -%}
  {%- endif -%}
{%- endfor -%}
